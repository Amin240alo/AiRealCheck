HIVE_API_KEY=your_hive_api_key_here
AIREALCHECK_USE_PAID_APIS=false
AIREALCHECK_JWT_SECRET=dev_change_me
AIREALCHECK_FREE_CREDITS=100
AIREALCHECK_ALLOW_ADMIN=false
# Local ML engine
AIREALCHECK_USE_LOCAL_ML=true
# Video URL checks
ALLOWED_VIDEO_DOMAINS=tiktok.com,instagram.com,youtube.com,youtu.be,cdninstagram.com
AIREALCHECK_MAX_VIDEO_MB=200
AIREALCHECK_MAX_VIDEO_SECONDS=0
# Set true to allow unlimited duration when MAX_VIDEO_SECONDS<=0
AIREALCHECK_ALLOW_UNLIMITED_VIDEO_SECONDS=false
AIREALCHECK_URL_REQUEST_TIMEOUT=30
AIREALCHECK_VIDEO_URL_MAX_LEN=2048
AIREALCHECK_TEMP_DIR=temp_upload
# Global scan fps for video sampling
AIREALCHECK_VIDEO_SCAN_FPS=2.0
# Video frame detectors
AIREALCHECK_VIDEO_DETECTOR_MAX_FRAMES=12
AIREALCHECK_VIDEO_DETECTOR_SCAN_FPS=1.5
AIREALCHECK_VIDEO_DETECTOR_TIMEOUT_SEC=20
# Video frame allocation per engine (uniform | scene | smart)
VIDEO_FRAMES_SIGHTENGINE=8
VIDEO_FRAMES_HIVE=4
VIDEO_FRAMES_RD=2
VIDEO_FRAMES_SENSITY=2
VIDEO_FRAMES_LOCAL=12
VIDEO_FRAME_STRATEGY=uniform
# Video frame selection (filters/dedup)
AIREALCHECK_VIDEO_FRAMES_EXTRACT=40
AIREALCHECK_VIDEO_FRAMES_SELECTED=12
AIREALCHECK_VIDEO_BRIGHTNESS_MIN=20
AIREALCHECK_VIDEO_BRIGHTNESS_MAX=235
AIREALCHECK_VIDEO_BLUR_MIN=60.0
AIREALCHECK_VIDEO_DEDUP=true
AIREALCHECK_VIDEO_RD_MAX_FRAMES=1
AIREALCHECK_VIDEO_TRIM=0.2
# Provider toggles
AIREALCHECK_ENABLE_REALITY_DEFENDER_VIDEO=false
AIREALCHECK_ENABLE_HIVE_VIDEO=false
AIREALCHECK_ENABLE_SENSITY_VIDEO=false
# Image provider toggles
AIREALCHECK_ENABLE_HIVE_IMAGE=false
AIREALCHECK_ENABLE_REALITY_DEFENDER_IMAGE=false
AIREALCHECK_ENABLE_SIGHTENGINE_IMAGE=false
AIREALCHECK_ENABLE_SENSITY_IMAGE=false
# Sensity API
SENSITY_API_KEY=
SENSITY_API_URL=
SENSITY_API_BASE_URL=
SENSITY_API_IMAGE_ENDPOINT=
SENSITY_API_FILE_FIELD=file
# Local temporal CNN toggle
AIREALCHECK_ENABLE_VIDEO_TEMPORAL_CNN=true
# Optional: override video weights via JSON, e.g. {"video_frame_detectors":0.2,"video_temporal":0.2}
# AIREALCHECK_VIDEO_ENGINE_WEIGHTS_JSON=
# Optional: override image weights via JSON, e.g. {"hive":0.3,"sightengine":0.2}
# AIREALCHECK_IMAGE_ENGINE_WEIGHTS_JSON=
# Optional: xception-only clamp behavior (image)
# AIREALCHECK_IMAGE_XCEPTION_CLAMP_ENABLED=true
# AIREALCHECK_IMAGE_XCEPTION_CLAMP_MIN=0.35
# AIREALCHECK_IMAGE_XCEPTION_CLAMP_MAX=0.65
# Optional: local image calibration (xception/clip only)
# AIREALCHECK_IMAGE_CALIBRATION_ENABLE=false
# AIREALCHECK_IMAGE_CALIBRATION_TEMPERATURE=1.0
# Optional: local robustness preprocessing (xception/clip only)
# AIREALCHECK_IMAGE_LOCAL_PREPROCESS=true
# Audio engine toggles (local)
AIREALCHECK_ENABLE_AUDIO_AASIST=true
AIREALCHECK_ENABLE_AUDIO_FORENSICS=true
AIREALCHECK_ENABLE_AUDIO_PROSODY=true
# Optional: also run audio forensics on video uploads
AIREALCHECK_ENABLE_AUDIO_FROM_VIDEO=false
# Legacy fallbacks (kept for compatibility)
AIREALCHECK_VIDEO_MAX_DETECTOR_FRAMES=20
# Optional: full path to ffmpeg.exe (or folder containing ffmpeg.exe)
FFMPEG_PATH=
# Paid API timeouts (connect/read)
AIREALCHECK_PAID_API_CONNECT_TIMEOUT_SEC=8
AIREALCHECK_PAID_API_READ_TIMEOUT_SEC=25
# Optional: path to a small video file for ffmpeg frame selftest
AIREALCHECK_FFMPEG_SELFTEST_VIDEO=
# Optional admin secret for /credits/grant when allow_admin=true
# AIREALCHECK_ADMIN_SECRET=change_me
