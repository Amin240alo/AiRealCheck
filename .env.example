############################
# APP CONFIGURATION
############################

# Environment label used by Backend/runtime.py (dev|test|prod) (OPTIONAL in production, not secret)
AIREALCHECK_ENV=development

# Flask environment label fallback used by Backend/runtime.py (OPTIONAL in production, not secret)
FLASK_ENV=

# Generic debug flag used by Backend/runtime.py (OPTIONAL in production, not secret)
DEBUG=

# Flask debug flag used by Backend/runtime.py (OPTIONAL in production, not secret)
FLASK_DEBUG=

# App debug flag for extra logging (Backend/runtime.py, Backend/engines/engine_utils.py) (OPTIONAL in production, not secret)
AIREALCHECK_DEBUG=true

# Include raw provider payloads in logs/results (Backend/analyses.py, Backend/deepfake_api.py) (OPTIONAL in production, not secret)
AIREALCHECK_DEBUG_RAW=false

# Verbose paid-API diagnostics (Backend/ensemble.py, Backend/engines/*) (OPTIONAL in production, not secret)
AIREALCHECK_DEBUG_PAID=false

# Verbose OAuth redirect logging (Backend/auth.py) (OPTIONAL in production, not secret)
AIREALCHECK_DEBUG_OAUTH=false

# Enable analysis caching (Backend/server.py) (OPTIONAL in production, not secret)
AIREALCHECK_CACHE=true

# Return integer scores in API responses (Backend/server.py) (OPTIONAL in production, not secret)
AIREALCHECK_RETURN_INTS=true

# Public API base URL for OAuth/email links (Backend/auth.py) (REQUIRED in production if auth/email enabled, not secret)
AIREALCHECK_PUBLIC_API_URL=http://localhost:5001

# Public web base URL for OAuth redirects and email links (Backend/auth.py) (REQUIRED in production if OAuth/email enabled, not secret)
AIREALCHECK_PUBLIC_WEB_URL=http://localhost:3000

############################
# SCORING / SHAPING
############################

# Enable legacy score shaping logic (Backend/server.py) (OPTIONAL in production, not secret)
AIREALCHECK_ENABLE_LEGACY_SHAPING=false

# Legacy alias for score shaping (Backend/server.py) (OPTIONAL in production, not secret)
AIREALCHECK_SCORE_SHAPING=false

# Gamma used for score shaping (Backend/server.py) (OPTIONAL in production, not secret)
AIREALCHECK_SHAPING_GAMMA=2.5

############################
# DATABASE
############################

# SQLAlchemy database URL (Backend/db.py) (REQUIRED in production, MUST stay secret)
DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/airealcheck

# Optional psql CLI URL used in README/scripts (OPTIONAL in production, secret if it contains creds)
DATABASE_URL_PSQL=postgresql://user:pass@localhost:5432/airealcheck

############################
# AUTHENTICATION
############################

# JWT signing secret for access tokens (Backend/middleware.py) (REQUIRED in production, MUST stay secret)
AIREALCHECK_JWT_SECRET=change_me

# Flask session secret used for OAuth (Backend/auth.py) (RECOMMENDED in production, MUST stay secret)
AIREALCHECK_SESSION_SECRET=change_me_too

# Access token lifetime in minutes (Backend/middleware.py) (OPTIONAL in production, not secret)
AIREALCHECK_ACCESS_TOKEN_MINUTES=480

# Refresh token lifetime in days (Backend/auth.py) (OPTIONAL in production, not secret)
AIREALCHECK_REFRESH_TOKEN_DAYS=30

# Email verification token lifetime in hours (Backend/auth.py) (OPTIONAL in production, not secret)
AIREALCHECK_VERIFY_TOKEN_HOURS=48

# Password reset token lifetime in hours (Backend/auth.py) (OPTIONAL in production, not secret)
AIREALCHECK_RESET_TOKEN_HOURS=2

# Refresh cookie name (Backend/auth.py) (OPTIONAL in production, not secret)
AIREALCHECK_REFRESH_COOKIE=aireal_refresh

# Force secure cookies; production overrides to true (Backend/auth.py) (OPTIONAL in production, not secret)
AIREALCHECK_COOKIE_SECURE=false

# SameSite for refresh cookies; empty uses defaults (Backend/auth.py) (OPTIONAL in production, not secret)
AIREALCHECK_COOKIE_SAMESITE=

############################
# GOOGLE OAUTH
############################

# Google OAuth client ID (Backend/auth.py) (REQUIRED in production if Google login enabled, not secret)
GOOGLE_CLIENT_ID=your_google_client_id

# Google OAuth client secret (Backend/auth.py) (REQUIRED in production if Google login enabled, MUST stay secret)
GOOGLE_CLIENT_SECRET=your_google_client_secret

# OAuth redirect URI override (Backend/auth.py) (REQUIRED in production if Google login enabled, not secret)
GOOGLE_REDIRECT_URI=http://localhost:5001/auth/google/callback

# Alternate Google OAuth client ID (Backend/auth.py) (OPTIONAL in production, not secret)
GOOGLE_OAUTH_CLIENT_ID=

# Alternate Google OAuth client secret (Backend/auth.py) (OPTIONAL in production, MUST stay secret)
GOOGLE_OAUTH_CLIENT_SECRET=

# Alternate Google OAuth redirect URI (Backend/auth.py) (OPTIONAL in production, not secret)
GOOGLE_OAUTH_REDIRECT_URI=

############################
# STRIPE
############################
# No Stripe variables referenced in code as of 2026-03-10.

############################
# EMAIL / SMTP
############################

# SMTP host for transactional email (Backend/emailer.py) (REQUIRED in production for email, not secret)
SMTP_HOST=smtp.example.com

# SMTP port (Backend/emailer.py) (REQUIRED in production for email, not secret)
SMTP_PORT=587

# SMTP username (Backend/emailer.py) (REQUIRED in production for email, not secret)
SMTP_USER=mailer@example.com

# SMTP password (Backend/emailer.py) (REQUIRED in production for email, MUST stay secret)
SMTP_PASS=your_smtp_password

# SMTP From address (Backend/emailer.py) (REQUIRED in production for email, not secret)
SMTP_FROM=AIRealCheck <mailer@example.com>

# Use STARTTLS (Backend/emailer.py) (OPTIONAL in production, not secret)
SMTP_USE_TLS=true

# Use SMTPS/SSL (Backend/emailer.py) (OPTIONAL in production, not secret)
SMTP_USE_SSL=false

# Print emails to console instead of SMTP (Backend/emailer.py) (DEV ONLY, not secret)
AIREALCHECK_EMAIL_DEV_CONSOLE=false

############################
# SECURITY
############################

# Allow admin endpoints (Backend/middleware.py) (OPTIONAL in production, not secret)
AIREALCHECK_ALLOW_ADMIN=false

# Allow unauthenticated/guest analyze (Backend/server.py) (OPTIONAL in production, not secret)
AIREALCHECK_ENABLE_GUEST_ANALYZE=false

############################
# FRONTEND (NEXT.JS)
############################

# Public API base URL for Next.js (frontend/next.config.ts, frontend/lib/api.ts) (REQUIRED for frontend, not secret)
NEXT_PUBLIC_API_URL=http://localhost:5001

############################
# CREDITS / BILLING
############################

# Free credits granted on signup (Backend/auth.py) (OPTIONAL in production, not secret)
AIREALCHECK_FREE_CREDITS=100

# Credit cost per image analysis (Backend/credits.py) (OPTIONAL in production, not secret)
AIREALCHECK_COST_IMAGE=15

# Credit cost per audio analysis (Backend/credits.py) (OPTIONAL in production, not secret)
AIREALCHECK_COST_AUDIO=20

# Credit cost for short videos (<30s) (Backend/credits.py) (OPTIONAL in production, not secret)
AIREALCHECK_COST_VIDEO_SHORT=30

# Credit cost per second for long videos (Backend/credits.py) (OPTIONAL in production, not secret)
AIREALCHECK_COST_VIDEO_PER_SEC=1

# Days before credits reset (Backend/credits.py) (OPTIONAL in production, not secret)
AIREALCHECK_CREDIT_RESET_DAYS=30

############################
# PAID API GLOBAL
############################

# Master switch for paid providers (Backend/server.py, Backend/ensemble.py) (OPTIONAL in production, not secret)
AIREALCHECK_USE_PAID_APIS=false

# Paid API connect timeout seconds (Backend/engines/*) (OPTIONAL in production, not secret)
AIREALCHECK_PAID_API_CONNECT_TIMEOUT_SEC=8

# Paid API read timeout seconds (Backend/engines/*) (OPTIONAL in production, not secret)
AIREALCHECK_PAID_API_READ_TIMEOUT_SEC=25

############################
# PROVIDER TOGGLES
############################

# Enable Hive image analysis (Backend/ensemble.py) (OPTIONAL in production, not secret)
AIREALCHECK_ENABLE_HIVE_IMAGE=false

# Enable Sightengine image analysis (Backend/ensemble.py) (OPTIONAL in production, not secret)
AIREALCHECK_ENABLE_SIGHTENGINE_IMAGE=false

# Enable Reality Defender image analysis (Backend/ensemble.py) (OPTIONAL in production, not secret)
AIREALCHECK_ENABLE_REALITY_DEFENDER_IMAGE=false

# Enable Sensity image analysis (Backend/ensemble.py) (OPTIONAL in production, not secret)
AIREALCHECK_ENABLE_SENSITY_IMAGE=false

# Enable Hive video analysis (Backend/engines/video_frame_detectors_engine.py) (OPTIONAL in production, not secret)
AIREALCHECK_ENABLE_HIVE_VIDEO=false

# Enable Sightengine video analysis (Backend/engines/video_frame_detectors_engine.py) (OPTIONAL in production, not secret)
AIREALCHECK_ENABLE_SIGHTENGINE_VIDEO=false

# Enable Reality Defender video analysis (Backend/engines/video_frame_detectors_engine.py) (OPTIONAL in production, not secret)
AIREALCHECK_ENABLE_REALITY_DEFENDER_VIDEO=false

# Enable Sensity video analysis (Backend/engines/video_frame_detectors_engine.py) (OPTIONAL in production, not secret)
AIREALCHECK_ENABLE_SENSITY_VIDEO=false

# Enable Reality Defender audio analysis (Backend/engines/reality_defender_audio_engine.py) (OPTIONAL in production, not secret)
AIREALCHECK_ENABLE_REALITY_DEFENDER_AUDIO=false

############################
# HIVE
############################

# Enable Hive integration globally (Backend/ensemble.py) (OPTIONAL in production, not secret)
HIVE_ENABLED=true

# Hive API key (Backend/deepfake_api.py, Backend/engines/hive_engine.py) (REQUIRED if Hive enabled, MUST stay secret)
HIVE_API_KEY=your_hive_api_key

