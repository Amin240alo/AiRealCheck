# Legacy alias for Hive API key (Backend/deepfake_api.py) (OPTIONAL, MUST stay secret)
AIREALCHECK_HIVE_API_KEY=

# Test-time augmentation count for Hive requests (Backend/deepfake_api.py) (OPTIONAL, not secret)
