AIREALCHECK_CLIP_MODEL=ViT-B-32

# CLIP pretrained weights source (Backend/engines/clip_detector_engine.py) (OPTIONAL, not secret)
AIREALCHECK_CLIP_PRETRAINED=openai

# Path to real-image embeddings (Backend/engines/clip_detector_engine.py) (OPTIONAL, not secret)
AIREALCHECK_CLIP_EMBEDDINGS_PATH=

# Legacy alias for embeddings path (Backend/engines/clip_detector_engine.py) (OPTIONAL, not secret)
AIREALCHECK_CLIP_EMBEDDINGS=

# Path to AI-image embeddings (Backend/engines/clip_detector_engine.py) (OPTIONAL, not secret)
AIREALCHECK_CLIP_AI_EMBEDDINGS_PATH=

# Top-K nearest neighbors for CLIP matching (Backend/engines/clip_detector_engine.py) (OPTIONAL, not secret)
AIREALCHECK_CLIP_TOPK=5

# Low similarity threshold for CLIP (Backend/engines/clip_detector_engine.py) (OPTIONAL, not secret)
AIREALCHECK_CLIP_SIM_LOW=0.18

# High similarity threshold for CLIP (Backend/engines/clip_detector_engine.py) (OPTIONAL, not secret)
AIREALCHECK_CLIP_SIM_HIGH=0.32

############################
# THRESHOLDS / WEIGHTS
############################

# Enable learned weights file (Backend/ensemble.py) (OPTIONAL in production, not secret)
AIREALCHECK_ENABLE_LEARNED_WEIGHTS=false

# Learned weights path (Backend/ensemble.py) (OPTIONAL in production, not secret)
AIREALCHECK_LEARNED_WEIGHTS_PATH=data/learned_weights.json

# Enable runtime thresholds from benchmark report (Backend/ensemble.py) (OPTIONAL in production, not secret)
AIREALCHECK_ENABLE_RUNTIME_THRESHOLDS=false

# Runtime thresholds path (Backend/ensemble.py) (OPTIONAL in production, not secret)
AIREALCHECK_RUNTIME_THRESHOLDS_PATH=data/benchmark_report.json

# Manual decision threshold override (0..1) (Backend/ensemble.py) (OPTIONAL in production, not secret)
AIREALCHECK_DECISION_THRESHOLD=

# JSON override for image engine weights (Backend/ensemble.py) (OPTIONAL in production, not secret)
AIREALCHECK_IMAGE_ENGINE_WEIGHTS_JSON=

# JSON override for video engine weights (Backend/ensemble.py) (OPTIONAL in production, not secret)
AIREALCHECK_VIDEO_ENGINE_WEIGHTS_JSON=

